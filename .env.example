# Lead capture webhook (n8n flow). The marketing site has no build
# step — values listed here are documentation only. To configure
# in production, edit public/config.js and replace the placeholder
# value of window.STK_CONFIG.LEAD_WEBHOOK_URL with the real URL.
#
# Body POSTed by the hero capsule:
#   {
#     "email":     string | null,
#     "query":     string | null,
#     "source":    "marketing-site-hero",
#     "timestamp": "<ISO 8601>"
#   }
LEAD_WEBHOOK_URL=
